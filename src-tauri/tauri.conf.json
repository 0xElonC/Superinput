{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Superinput",
  "version": "0.1.0",
  "identifier": "com.superinput.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Superinput",
        "width": 820,
        "height": 640,
        "minWidth": 680,
        "minHeight": 560,
        "decorations": true,
        "resizable": true,
        "alwaysOnTop": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}

